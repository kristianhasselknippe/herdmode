{
  "name": "herdmode",
  "version": "0.1.0",
  "private": true,
  "description": "Wrangle your Claude Code agents",
  "author": "Kristian Hasselknippe",
  "homepage": "https://github.com/kristianhasselknippe/herdmode",
  "main": "dist/main.js",
  "scripts": {
    "dev": "electron dist/main.js",
    "build:ts": "esbuild src/main.ts src/preload.ts --bundle --platform=node --outdir=dist --external:electron",
    "build:web": "cd ../web && bun run build",
    "build": "bun run build:web && bun run build:ts",
    "dist": "bun run build && bunx electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "hono": "^4",
    "@hono/node-server": "^1",
    "ws": "^8"
  },
  "devDependencies": {
    "electron": "^35",
    "electron-builder": "^26",
    "esbuild": "^0.27",
    "@types/ws": "^8",
    "typescript": "^5"
  }
}
